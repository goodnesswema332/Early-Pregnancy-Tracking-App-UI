# Required - production values
MONGODB_URI=
JWT_SECRET=
FRONTEND_URL=
PORT=5000

# Optional / sensible defaults
NODE_ENV=production
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# Cloudflare R2 / S3-compatible storage (optional)
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
AWS_REGION=auto

# Admin seeding / bootstrap (optional)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_ROLE=super
ADMIN_CREATE_SECRET=

# Super admin bootstrap (optional script `scripts/bootstrapSuperAdmin.ts`)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
