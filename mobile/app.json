{
  "expo": {
    "sdkVersion": "54.0.0",
    "name": "Early Pregnancy Prevention",
    "slug": "pregnancy-prevention-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#14B8A6"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.youngscientistkenya.pregnancyprevention"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14B8A6"
      },
      "package": "com.youngscientistkenya.pregnancyprevention",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-audio", "expo-video", "expo-asset"],
    "extra": {
      "eas": {
        "projectId": "5a61d90d-1fdb-4e7c-a017-bbe06d496910"
      }
    },
    "owner": "goodness_wema"
  }
}
